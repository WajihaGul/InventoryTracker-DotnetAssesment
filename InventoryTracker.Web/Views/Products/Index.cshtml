@model List<InventoryTracker.Web.ViewModels.ProductListItemVm>

@{
    ViewData["Title"] = "Products";
    var search = ViewData["Search"] as string;
}

<h1>Products</h1>

<div class="mb-3 d-flex justify-content-between align-items-center">
    <form method="get" class="d-flex" style="gap: 8px;">
        <input type="text" name="search" value="@search" class="form-control"
               placeholder="Search by SKU or name" />
        <button type="submit" class="btn btn-outline-secondary">Search</button>
    </form>
    <a asp-action="Create" class="btn btn-primary">+ Add Product</a>
</div>

@if (!Model.Any())
{
    <p class="text-muted">No products found.</p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>SKU</th>
                <th>Name</th>
                <th>Stock</th>
                <th>Reorder Level</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Sku</td>
                    <td>@p.Name</td>
                    <td>
                        @p.StockLevel
                        @if (p.IsLowStock)
                        {
                            <span class="badge bg-danger">Low stock</span>
                        }
                    </td>
                    <td>@p.ReorderLevel</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">View</a>
                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}